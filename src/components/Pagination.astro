---
import type { PaginationNeighbor } from '~/lib/pagination';

interface Props {
  prev?: PaginationNeighbor;
  next?: PaginationNeighbor;
}

const { prev, next } = Astro.props;
---

{(prev || next) && (
  <nav
    aria-label="Page navigation"
    class="mt-12 grid gap-3 border-t border-border pt-6 sm:grid-cols-2"
  >
    {prev ? (
      <a
        href={prev.href}
        rel="prev"
        class="group block rounded-lg border border-border bg-card p-4 transition hover:border-primary hover:bg-accent/40"
      >
        <div class="text-xs font-semibold uppercase tracking-wider text-muted-foreground">
          ← Previous · {prev.categoryTitle}
        </div>
        <div class="mt-1 font-semibold text-foreground group-hover:text-primary">
          {prev.title}
        </div>
      </a>
    ) : (
      <div class="hidden sm:block" aria-hidden="true"></div>
    )}
    {next && (
      <a
        href={next.href}
        rel="next"
        class="group block rounded-lg border border-border bg-card p-4 transition hover:border-primary hover:bg-accent/40 sm:text-right"
      >
        <div class="text-xs font-semibold uppercase tracking-wider text-muted-foreground">
          Next · {next.categoryTitle} →
        </div>
        <div class="mt-1 font-semibold text-foreground group-hover:text-primary">
          {next.title}
        </div>
      </a>
    )}
  </nav>
)}
