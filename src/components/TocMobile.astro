---
// Mobile/medium "On this page" — collapsible <details> that mirrors the
// right-rail TOC. Shown only on viewports < xl (where the sticky right
// TOC is hidden). Native <details> means it works without any JS.

import type { MarkdownHeading } from 'astro';

interface Props {
  headings: MarkdownHeading[];
}

const { headings } = Astro.props;

// Match the right-rail TOC: H2 and H3 only (H1 is the page title).
const filtered = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
---

{filtered.length > 0 && (
  <details class="toc-mobile group mb-6 rounded-md border border-zinc-200 bg-zinc-50 xl:hidden dark:border-zinc-800 dark:bg-zinc-900/50">
    <summary class="flex cursor-pointer list-none items-center justify-between gap-2 px-3.5 py-2.5 text-xs font-semibold uppercase tracking-wider text-zinc-700 hover:text-zinc-900 dark:text-zinc-300 dark:hover:text-zinc-100">
      <span class="flex items-center gap-2">
        <span aria-hidden="true">📑</span>
        <span>On this page</span>
        <span class="font-normal lowercase tracking-normal text-zinc-400 dark:text-zinc-500">
          ({filtered.length} {filtered.length === 1 ? 'section' : 'sections'})
        </span>
      </span>
      <svg
        class="size-4 transition-transform group-open:rotate-180"
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <polyline points="6 9 12 15 18 9" />
      </svg>
    </summary>
    <nav aria-label="Table of contents" class="border-t border-zinc-200 px-3.5 py-3 text-sm dark:border-zinc-800">
      <ul class="space-y-1.5">
        {filtered.map((h) => (
          <li>
            <a
              href={`#${h.slug}`}
              class:list={[
                'block text-zinc-700 transition hover:text-accent-700 dark:text-zinc-300 dark:hover:text-accent-300',
                h.depth === 3 && 'pl-4 text-zinc-500 dark:text-zinc-500',
              ]}
            >
              {h.text}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </details>
)}

<style>
  /* Safari renders the default disclosure triangle even when list-style
     is none. Belt-and-suspenders. */
  .toc-mobile summary::-webkit-details-marker { display: none; }
  .toc-mobile summary::marker { display: none; content: ''; }
</style>
