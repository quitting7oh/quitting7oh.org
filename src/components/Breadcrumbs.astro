---
// Breadcrumb trail: "Home > Category > Page".
// Pass a `crumbs` array of {label, href?} — the last item is treated as
// the current page (no link, aria-current="page"). "Home" is always
// prepended automatically.

export interface Crumb {
  label: string;
  href?: string;
}

interface Props {
  crumbs: Crumb[];
}

const { crumbs } = Astro.props;
// Always lead with Home; caller passes the rest (category, current page).
const all: Crumb[] = [{ label: 'Home', href: '/' }, ...crumbs];
---

<nav
  aria-label="Breadcrumb"
  class="mb-4 text-xs font-semibold uppercase tracking-wider"
>
  <ol class="flex flex-wrap items-center gap-x-1.5 gap-y-1 text-zinc-500 dark:text-zinc-400">
    {all.map((c, i) => {
      const isLast = i === all.length - 1;
      return (
        <li class="flex items-center gap-x-1.5">
          {c.href && !isLast ? (
            <a
              href={c.href}
              class="text-accent-700 transition hover:text-accent-800 hover:underline dark:text-accent-300 dark:hover:text-accent-200"
            >
              {c.label}
            </a>
          ) : (
            <span class="text-zinc-700 dark:text-zinc-300" aria-current={isLast ? 'page' : undefined}>
              {c.label}
            </span>
          )}
          {!isLast && (
            <span aria-hidden="true" class="select-none text-zinc-400 dark:text-zinc-600">
              ›
            </span>
          )}
        </li>
      );
    })}
  </ol>
</nav>
