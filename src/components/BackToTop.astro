---
// Floating "back to top" button. Mounted globally in BaseLayout.
//
// - Hidden by default; fades in when scrolled past 400px.
// - Smooth-scrolls to the top on click (instant if prefers-reduced-motion).
// - Keyboard accessible (Tab into it; Enter/Space activates).
// - Below modal-layer z-indices so it doesn't sit on top of the mobile
//   sidebar drawer or its backdrop.
---

<button
  id="back-to-top"
  type="button"
  class="back-to-top fixed bottom-6 right-6 z-20 inline-flex h-11 w-11 items-center justify-center rounded-full border border-accent-700 bg-accent-600 text-white shadow-lg ring-1 ring-black/5 transition hover:bg-accent-700 hover:shadow-xl focus-visible:outline-none focus-visible:ring-4 focus-visible:ring-accent-300 sm:bottom-8 sm:right-8 dark:border-accent-400 dark:bg-accent-500 dark:hover:bg-accent-400 dark:focus-visible:ring-accent-800"
  aria-label="Back to top"
  aria-hidden="true"
  tabindex="-1"
>
  <svg
    xmlns="http://www.w3.org/2000/svg"
    width="20"
    height="20"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2.25"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <line x1="12" y1="19" x2="12" y2="5" />
    <polyline points="5 12 12 5 19 12" />
  </svg>
</button>

<style>
  /* Visibility transitions — hidden by default, shown when the JS adds
     .shown after the user has scrolled past the threshold. */
  .back-to-top {
    opacity: 0;
    pointer-events: none;
    transform: translateY(8px);
    transition: opacity 200ms ease, transform 200ms ease;
  }
  .back-to-top.shown {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }
</style>

<script>
  const btn = document.getElementById('back-to-top');
  if (btn) {
    const SHOW_AFTER_PX = 400;
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');

    function update() {
      const shown = window.scrollY > SHOW_AFTER_PX;
      btn.classList.toggle('shown', shown);
      btn.setAttribute('aria-hidden', String(!shown));
      // Only focusable when visible — keeps it out of tab order when hidden.
      btn.setAttribute('tabindex', shown ? '0' : '-1');
    }

    window.addEventListener('scroll', update, { passive: true });
    update();

    btn.addEventListener('click', () => {
      window.scrollTo({
        top: 0,
        behavior: prefersReducedMotion.matches ? 'auto' : 'smooth',
      });
      // Move focus off the button so it can fade out cleanly.
      btn.blur();
    });
  }
</script>
