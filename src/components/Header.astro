---
import ThemeToggle from './ThemeToggle.astro';
import SearchBox from './SearchBox.astro';
import { SITE } from '~/lib/site';
---

<header
  class="sticky top-0 z-30 border-b border-zinc-200 bg-white/85 backdrop-blur dark:border-zinc-800 dark:bg-zinc-950/85"
>
  <div class="mx-auto flex max-w-[88rem] items-center gap-4 px-4 py-3 sm:px-6 lg:px-8">
    <button
      id="nav-toggle"
      type="button"
      class="-ml-2 inline-flex h-9 w-9 items-center justify-center rounded-md text-zinc-600 hover:bg-zinc-100 lg:hidden dark:text-zinc-300 dark:hover:bg-zinc-800"
      aria-label="Open navigation"
      aria-controls="site-sidebar"
      aria-expanded="false"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
        <line x1="3" y1="6" x2="21" y2="6" />
        <line x1="3" y1="12" x2="21" y2="12" />
        <line x1="3" y1="18" x2="21" y2="18" />
      </svg>
    </button>

    <a
      href="/"
      class="flex items-center gap-2 text-base font-semibold tracking-tight text-zinc-900 dark:text-zinc-50"
    >
      <span class="inline-block h-2.5 w-2.5 rounded-full bg-accent-500" aria-hidden="true"></span>
      <span>{SITE.title}<span class="text-zinc-400">.org</span></span>
    </a>

    <div class="ml-auto flex items-center gap-3">
      <div class="hidden sm:block">
        <SearchBox variant="header" />
      </div>
      <ThemeToggle />
    </div>
  </div>

  <!-- Mobile-only search row -->
  <div class="border-t border-zinc-200 px-4 py-2 sm:hidden dark:border-zinc-800">
    <SearchBox variant="header" />
  </div>
</header>

<script>
  const btn = document.getElementById('nav-toggle');
  const sidebar = document.getElementById('site-sidebar');
  const backdrop = document.getElementById('site-sidebar-backdrop');
  const closeBtn = document.getElementById('sidebar-close');

  function setSidebarOpen(open: boolean) {
    if (!sidebar) return;
    sidebar.classList.toggle('open', open);
    backdrop?.classList.toggle('open', open);
    btn?.setAttribute('aria-expanded', String(open));
    sidebar.setAttribute('aria-hidden', String(!open));
    document.body.classList.toggle('overflow-hidden', open);
  }

  btn?.addEventListener('click', () => {
    const isOpen = sidebar?.classList.contains('open');
    setSidebarOpen(!isOpen);
  });
  backdrop?.addEventListener('click', () => setSidebarOpen(false));
  closeBtn?.addEventListener('click', () => setSidebarOpen(false));

  // Close on Escape — standard a11y for modal-style drawers.
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && sidebar?.classList.contains('open')) {
      setSidebarOpen(false);
      btn?.focus();
    }
  });

  // On desktop the sidebar is always visible (sticky), so aria-hidden must
  // not be true. Sync once on load and on breakpoint changes.
  const desktopMQ = window.matchMedia('(min-width: 1024px)');
  function syncAriaForBreakpoint() {
    if (!sidebar) return;
    if (desktopMQ.matches) {
      sidebar.setAttribute('aria-hidden', 'false');
    } else if (!sidebar.classList.contains('open')) {
      sidebar.setAttribute('aria-hidden', 'true');
    }
  }
  syncAriaForBreakpoint();
  desktopMQ.addEventListener('change', syncAriaForBreakpoint);
</script>
