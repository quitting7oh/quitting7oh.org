---
import { ThemePicker } from './ThemePicker';
import { SearchBox } from './SearchBox';
import { SITE } from '~/lib/site';
---

<header
  class="sticky top-0 z-30 border-b border-border bg-background/85 backdrop-blur"
>
  <div class="mx-auto flex max-w-[88rem] items-center gap-4 px-4 py-3 sm:px-6 lg:px-8">
    <button
      id="nav-toggle"
      type="button"
      class="-ml-2 inline-flex h-9 w-9 items-center justify-center rounded-md text-muted-foreground hover:bg-accent hover:text-accent-foreground lg:hidden"
      aria-label="Open navigation"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
        <line x1="3" y1="6" x2="21" y2="6" />
        <line x1="3" y1="12" x2="21" y2="12" />
        <line x1="3" y1="18" x2="21" y2="18" />
      </svg>
    </button>

    <a
      href="/"
      class="flex items-center gap-2 text-base font-semibold tracking-tight text-foreground"
    >
      <span class="inline-block h-2.5 w-2.5 rounded-full bg-primary" aria-hidden="true"></span>
      <span>{SITE.title}<span class="text-muted-foreground">.org</span></span>
    </a>

    <div class="ml-auto flex items-center gap-3">
      <div class="hidden sm:block">
        <SearchBox variant="header" client:load />
      </div>
      <ThemePicker client:load />
    </div>
  </div>

  <!-- Mobile-only search row -->
  <div class="border-t border-border px-4 py-2 sm:hidden">
    <SearchBox variant="header" client:load />
  </div>
</header>

<script>
  // The mobile hamburger lives outside the React SidebarShell tree, so it
  // dispatches a custom event the AppSidebar listens for.
  const btn = document.getElementById('nav-toggle');
  btn?.addEventListener('click', () => {
    window.dispatchEvent(new CustomEvent('toggle-sidebar'));
  });
</script>
