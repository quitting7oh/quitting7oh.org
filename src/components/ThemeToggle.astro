---
// Three-state theme toggle: system → light → dark → system.
// The active state is reflected in data-theme-mode on <html>.
---
<button
  id="theme-toggle"
  type="button"
  class="inline-flex h-9 w-9 items-center justify-center rounded-md border border-zinc-200 text-zinc-600 transition hover:bg-zinc-100 hover:text-zinc-900 dark:border-zinc-700 dark:text-zinc-300 dark:hover:bg-zinc-800 dark:hover:text-zinc-50"
  aria-label="Theme: system, click to change"
>
  <!-- Icons swapped by script. Default markup is the 'system' icon (monitor). -->
  <svg data-icon="system" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <rect x="2" y="3" width="20" height="14" rx="2" />
    <line x1="8" y1="21" x2="16" y2="21" />
    <line x1="12" y1="17" x2="12" y2="21" />
  </svg>
  <svg data-icon="light" class="hidden" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <circle cx="12" cy="12" r="4" />
    <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41" />
  </svg>
  <svg data-icon="dark" class="hidden" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
  </svg>
</button>

<script is:inline>
  (function () {
    var btn = document.getElementById('theme-toggle');
    if (!btn) return;
    var root = document.documentElement;
    var mql = window.matchMedia('(prefers-color-scheme: dark)');

    function showIcon(mode) {
      var icons = btn.querySelectorAll('svg[data-icon]');
      icons.forEach(function (el) {
        el.classList.toggle('hidden', el.dataset.icon !== mode);
      });
      var nextLabel = mode === 'system' ? 'light' : mode === 'light' ? 'dark' : 'system';
      btn.setAttribute('aria-label', 'Theme: ' + mode + ', click to change to ' + nextLabel);
    }

    function applyMode(mode) {
      root.dataset.themeMode = mode;
      var dark = mode === 'dark' || (mode === 'system' && mql.matches);
      root.classList.toggle('dark', dark);
      showIcon(mode);
    }

    // Initialize button icon from whatever the inline script set.
    var initial = root.dataset.themeMode || localStorage.getItem('theme') || 'system';
    showIcon(initial);

    btn.addEventListener('click', function () {
      var current = root.dataset.themeMode || 'system';
      var next = current === 'system' ? 'light' : current === 'light' ? 'dark' : 'system';
      if (next === 'system') localStorage.removeItem('theme');
      else localStorage.setItem('theme', next);
      applyMode(next);
    });
  })();
</script>
