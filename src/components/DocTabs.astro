---
// DocTabs — server-rendered tabs for long doc pages.
//
// Why an Astro component (not React):
//   Astro + MDX + a client-hydrated React component with rich JSX+markdown
//   children silently drops the children at SSR. Plain Astro components
//   render the children server-side fine, and we get the interactivity
//   we need from a small inline <script>.
//
// Properties:
//   - All tab panels are present in the SSR HTML (good for SEO, deep
//     linking, and view-source).
//   - Inactive panels use the HTML `hidden="until-found"` attribute, so
//     browser find-in-page (Ctrl+F) still locates text in them — and the
//     browser fires `beforematch` when it does, which we hook to switch
//     to the right tab.
//   - Initial tab is the first <DocTabPanel> child, OR whichever tab
//     contains the URL hash anchor on load.
//   - Hash changes (e.g. clicks on TOC anchors) auto-switch tabs.
//
// Usage in MDX:
//
//   import DocTabs from '~/components/DocTabs.astro';
//   import DocTabPanel from '~/components/DocTabPanel.astro';
//
//   <DocTabs>
//     <DocTabPanel value="a" label="First">
//
//     ## Heading inside the first tab
//
//     </DocTabPanel>
//     <DocTabPanel value="b" label="Second">
//
//     ## Second tab heading
//
//     </DocTabPanel>
//   </DocTabs>
//
// DocTabPanel.astro renders a div with data-tab-panel + data-tab-label
// attributes; this component scans Astro.slots / its children to build
// the tab list. Because the children are emitted as opaque HTML by the
// time we see them, we extract panel metadata client-side from the
// rendered DOM instead of trying to read it server-side.

import { randomBytes } from 'node:crypto';
const id = 'doctabs-' + randomBytes(4).toString('hex');
---

<div class="doc-tabs my-6" data-doctabs id={id}>
  {/* Tab list is built client-side from the data-tab-panel elements
      inside this container. We render a placeholder here so there's no
      layout shift; the script populates it on mount. */}
  <div
    role="tablist"
    aria-label="Page sections"
    class="doc-tabs-list flex flex-wrap items-end gap-1 border-b border-border"
  ></div>
  <div class="doc-tabs-panels pt-6">
    <slot />
  </div>
</div>

<script is:inline define:vars={{ id }}>
  (function () {
    const root = document.getElementById(id);
    if (!root) return;
    const listEl = root.querySelector('.doc-tabs-list');
    const panelEls = Array.from(
      root.querySelectorAll(':scope > .doc-tabs-panels > [data-tab-panel]'),
    );
    if (panelEls.length === 0) return;

    // Build the anchor → tab value map from heading IDs inside each panel.
    const anchorToTab = new Map();
    panelEls.forEach((panel) => {
      const value = panel.getAttribute('data-tab-panel');
      panel.querySelectorAll('[id]').forEach((el) => {
        if (el.id) anchorToTab.set(el.id, value);
      });
    });

    // Determine initial active tab.
    let active = panelEls[0].getAttribute('data-tab-panel');
    const initialHash = window.location.hash.slice(1);
    if (initialHash && anchorToTab.has(initialHash)) {
      active = anchorToTab.get(initialHash);
    }

    // Build the tab list buttons.
    panelEls.forEach((panel) => {
      const value = panel.getAttribute('data-tab-panel');
      const label = panel.getAttribute('data-tab-label') || value;
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.setAttribute('role', 'tab');
      btn.setAttribute('data-tab-trigger', value);
      btn.id = `tab-${id}-${value}`;
      btn.setAttribute('aria-controls', `tabpanel-${id}-${value}`);
      btn.className =
        'doc-tab-trigger relative -mb-px inline-flex h-10 items-center justify-center whitespace-nowrap border-b-2 border-transparent px-4 text-sm font-semibold text-muted-foreground transition-colors hover:text-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2';
      btn.textContent = label;
      btn.addEventListener('click', () => setActive(value));
      listEl.appendChild(btn);
    });

    // Apply ARIA + ids to the rendered panels (the panel div is already
    // in the DOM from the Astro slot; we just annotate it).
    panelEls.forEach((panel) => {
      const value = panel.getAttribute('data-tab-panel');
      panel.setAttribute('role', 'tabpanel');
      panel.setAttribute('aria-labelledby', `tab-${id}-${value}`);
      panel.id = `tabpanel-${id}-${value}`;
    });

    function setActive(value) {
      active = value;
      panelEls.forEach((panel) => {
        const v = panel.getAttribute('data-tab-panel');
        if (v === active) {
          panel.removeAttribute('hidden');
        } else {
          // "until-found" keeps the element discoverable by browser
          // find-in-page. When the browser matches text inside, it
          // fires `beforematch` and removes the attribute itself; we
          // hook that to also flip the active tab.
          panel.setAttribute('hidden', 'until-found');
        }
      });
      listEl.querySelectorAll('[data-tab-trigger]').forEach((btn) => {
        const v = btn.getAttribute('data-tab-trigger');
        const isActive = v === active;
        btn.setAttribute('aria-selected', String(isActive));
        if (isActive) {
          btn.classList.add('border-primary', 'text-foreground');
          btn.classList.remove('border-transparent', 'text-muted-foreground');
        } else {
          btn.classList.remove('border-primary', 'text-foreground');
          btn.classList.add('border-transparent', 'text-muted-foreground');
        }
      });
    }

    // Initial state.
    setActive(active);

    // If the initial hash targets an anchor inside a (now active) tab,
    // scroll to it after the panel becomes visible.
    if (initialHash && anchorToTab.has(initialHash)) {
      requestAnimationFrame(() => {
        const el = document.getElementById(initialHash);
        el?.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
    }

    // Hash changes after load (e.g., reader clicks a TOC link).
    window.addEventListener('hashchange', () => {
      const hash = window.location.hash.slice(1);
      if (hash && anchorToTab.has(hash)) {
        setActive(anchorToTab.get(hash));
      }
    });

    // Browser find-in-page matched text inside an inactive panel.
    document.addEventListener('beforematch', (e) => {
      const target = e.target;
      const panel = target?.closest?.('[data-tab-panel]');
      if (panel && root.contains(panel)) {
        const v = panel.getAttribute('data-tab-panel');
        if (v) setActive(v);
      }
    });
  })();
</script>
