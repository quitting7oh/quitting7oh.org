---
// Inline, runs *before* the page renders — prevents flash of incorrect theme.
//
// Two pieces of theme state:
//   - mode    : 'system' | 'light' | 'dark'                       (key: 'theme')
//   - variant : 'accent-teal' | 'zinc' | 'slate' | 'stone' |
//               'neutral' | 'rose' | 'blue' | 'green'             (key: 'theme-variant')
//
// Defaults: mode=system, variant=accent-teal (the absence of localStorage
// values implies the defaults; we don't write defaults to localStorage so
// it's easy to tell "user picked this" from "user hasn't picked anything").
---
<script is:inline>
  (function () {
    try {
      var storedMode = localStorage.getItem('theme'); // 'system' | 'light' | 'dark' | null
      var storedVariant = localStorage.getItem('theme-variant'); // 'zinc' | ... | null
      var mql = window.matchMedia('(prefers-color-scheme: dark)');
      var root = document.documentElement;

      var mode = storedMode || 'system';
      var dark = mode === 'dark' || (mode === 'system' && mql.matches);
      if (dark) root.classList.add('dark');
      else root.classList.remove('dark');
      root.dataset.themeMode = mode;

      var variant = storedVariant || 'accent-teal';
      if (variant === 'accent-teal') {
        // Default; no attribute needed (the :root rule covers it).
        delete root.dataset.theme;
      } else {
        root.dataset.theme = variant;
      }

      // Live OS-theme updates while in 'system' mode.
      mql.addEventListener('change', function (e) {
        if ((localStorage.getItem('theme') || 'system') !== 'system') return;
        if (e.matches) root.classList.add('dark');
        else root.classList.remove('dark');
      });
    } catch (e) {
      // localStorage may be blocked; default to system via media query.
      if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
        document.documentElement.classList.add('dark');
      }
    }
  })();
</script>
