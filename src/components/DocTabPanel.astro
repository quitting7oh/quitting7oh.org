---
// DocTabPanel — one panel inside a <DocTabs>. The parent component
// discovers panels by querying for [data-tab-panel] children, reads
// the label from data-tab-label, and applies hidden="until-found"
// to inactive ones.

interface Props {
  value: string;
  label: string;
}

const { value, label } = Astro.props;
---

<div data-tab-panel={value} data-tab-label={label}>
  <slot />
</div>
