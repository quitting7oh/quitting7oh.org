    <div class="cell" style="--c:#f0506e">
      <div class="fbox">
        <div class="frow"><span class="flab">Molecular formula</span><span class="fval">C₂₃H₃₀N₂O₅</span></div>
        <div class="frow"><span class="flab">Molecular weight</span><span class="fval">414.50 g/mol</span></div>
