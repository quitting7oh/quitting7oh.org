---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { Breadcrumbs } from '~/components/Breadcrumbs';
import { getCollection } from 'astro:content';
import { CATEGORIES } from '~/lib/categories';
import { SITE } from '~/lib/site';

const docs = await getCollection('docs', (d) => !d.data.draft);

// Group docs by category, sorted by `sort` then alphabetically.
const sections = CATEGORIES.map((cat) => ({
  ...cat,
  items: docs
    .filter((d) => d.data.category === cat.slug)
    .sort((a, b) => {
      const sa = a.data.sort ?? 999;
      const sb = b.data.sort ?? 999;
      if (sa !== sb) return sa - sb;
      return a.data.title.localeCompare(b.data.title);
    }),
}));

/** Top-level pages that don't live in the docs content collection but
 *  are publicly linked and worth surfacing on the human-facing sitemap.
 *  Keep this list curated — the XML sitemap at /sitemap-index.xml
 *  catches every generated page automatically; this is for the people
 *  scanning /sitemap by eye. */
const STANDALONE_PAGES: { href: string; title: string; description: string }[] = [
  {
    href: '/next-kratom-support-meeting',
    title: 'Next kratom support meeting',
    description:
      'Rolling 3-day schedule for Kratom Anonymous and TIAWO meetings — featured "Next up" card, live countdowns, one click to join.',
  },
];

const totalPages = docs.length + STANDALONE_PAGES.length;
---

<BaseLayout
  title="Site map"
  description="Every page on quitting7oh.org, organized by category."
>
  <main id="main-content" class="mx-auto max-w-6xl px-4 py-10 sm:px-6 sm:py-12 lg:px-8">
    <header class="border-b border-zinc-200 pb-6 dark:border-zinc-800">
      <Breadcrumbs client:load crumbs={[{ label: 'Site map' }]} />
      <h1 class="text-3xl font-bold tracking-tight text-zinc-900 sm:text-4xl dark:text-zinc-50">
        Site map
      </h1>
      <p class="mt-3 text-lg text-zinc-600 dark:text-zinc-400">
        Every page on {SITE.domain}, organized by category. Currently
        {totalPages} {totalPages === 1 ? 'page' : 'pages'} across {CATEGORIES.length} sections.
      </p>
      <p class="mt-3 text-sm text-zinc-500 dark:text-zinc-500">
        Looking for the search-engine sitemap?
        See <a href="/sitemap-index.xml" class="text-accent-700 underline decoration-accent-300 underline-offset-2 dark:text-accent-300 dark:decoration-accent-700">/sitemap-index.xml</a>.
      </p>
    </header>

    <div class="mt-10 space-y-12">
      {sections.map((cat) => (
        <section aria-labelledby={`cat-${cat.slug}`}>
          <div class="flex items-center gap-3">
            <cat.Icon class="h-6 w-6 shrink-0 text-muted-foreground" aria-hidden="true" />
            <h2 id={`cat-${cat.slug}`} class="text-2xl font-semibold tracking-tight text-zinc-900 dark:text-zinc-50">
              <a href={`/${cat.slug}`} class="hover:text-accent-700 dark:hover:text-accent-300">
                {cat.title}
              </a>
            </h2>
            <span class="text-sm text-zinc-400 dark:text-zinc-500">
              ({cat.items.length} {cat.items.length === 1 ? 'page' : 'pages'})
            </span>
          </div>
          <p class="mt-2 text-sm text-zinc-600 dark:text-zinc-400">{cat.blurb}</p>

          {cat.items.length === 0 ? (
            <p class="mt-4 text-sm italic text-zinc-400 dark:text-zinc-500">No pages yet.</p>
          ) : (
            <ul class="mt-4 divide-y divide-zinc-200 border-y border-zinc-200 dark:divide-zinc-800 dark:border-zinc-800">
              {cat.items.map((item) => {
                const slug = item.id.split('/').pop()!;
                const href = `/${item.data.category}/${slug}`;
                return (
                  <li class="py-3">
                    <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1">
                      <a
                        href={href}
                        class="font-medium text-zinc-900 hover:text-accent-700 dark:text-zinc-50 dark:hover:text-accent-300"
                      >
                        {item.data.title}
                      </a>
                    </div>
                    {item.data.description && (
                      <p class="mt-1 text-sm text-zinc-600 dark:text-zinc-400">
                        {item.data.description}
                      </p>
                    )}
                  </li>
                );
              })}
            </ul>
          )}
        </section>
      ))}
    </div>

    {STANDALONE_PAGES.length > 0 && (
      <section aria-labelledby="cat-standalone" class="mt-12">
        <div class="flex items-center gap-3">
          <h2 id="cat-standalone" class="text-2xl font-semibold tracking-tight text-zinc-900 dark:text-zinc-50">
            Standalone tools
          </h2>
          <span class="text-sm text-zinc-400 dark:text-zinc-500">
            ({STANDALONE_PAGES.length} {STANDALONE_PAGES.length === 1 ? 'page' : 'pages'})
          </span>
        </div>
        <p class="mt-2 text-sm text-zinc-600 dark:text-zinc-400">
          Live, shareable landing pages that don't belong to a category — designed to be linked directly.
        </p>
        <ul class="mt-4 divide-y divide-zinc-200 border-y border-zinc-200 dark:divide-zinc-800 dark:border-zinc-800">
          {STANDALONE_PAGES.map((item) => (
            <li class="py-3">
              <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1">
                <a
                  href={item.href}
                  class="font-medium text-zinc-900 hover:text-accent-700 dark:text-zinc-50 dark:hover:text-accent-300"
                >
                  {item.title}
                </a>
              </div>
              <p class="mt-1 text-sm text-zinc-600 dark:text-zinc-400">
                {item.description}
              </p>
            </li>
          ))}
        </ul>
      </section>
    )}

    <footer class="mt-16 border-t border-zinc-200 pt-6 text-sm text-zinc-500 dark:border-zinc-800 dark:text-zinc-500">
      <p>
        Don't see a topic you expected? The site is community-maintained — open
        an issue or pull request on
        <a href={SITE.repo} target="_blank" rel="noopener noreferrer" class="text-accent-700 underline decoration-accent-300 underline-offset-2 dark:text-accent-300 dark:decoration-accent-700">GitHub</a>,
        or come find us in the
        <a href="/about/the-community" class="text-accent-700 underline decoration-accent-300 underline-offset-2 dark:text-accent-300 dark:decoration-accent-700">Discord and subreddit</a>.
      </p>
    </footer>
  </main>
</BaseLayout>
