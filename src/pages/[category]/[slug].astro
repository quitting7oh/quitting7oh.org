---
import { getCollection, render } from 'astro:content';
import DocLayout from '~/layouts/DocLayout.astro';
import { CATEGORY_SLUGS } from '~/lib/categories';

export async function getStaticPaths() {
  const docs = await getCollection('docs', (d) => !d.data.draft);
  return docs.map((doc) => {
    // Astro v5's glob loader strips the extension from doc.id, so it looks
    // like "start-here/welcome" (no .md). Just take the last path segment.
    const slug = doc.id.split('/').pop()!;
    return {
      params: { category: doc.data.category, slug },
      props: { doc },
    };
  });
}

const { doc } = Astro.props;
const { Content, headings } = await render(doc);

// `doc.filePath` is the on-disk path (e.g. "src/content/start-here/welcome.md")
// — use it to construct the GitHub edit link with the correct extension.
// Falls back to `<id>.md` for backwards compat if filePath is missing.
const CONTENT_ROOT = 'src/content/';
const fp = doc.filePath ?? '';
const idx = fp.indexOf(CONTENT_ROOT);
const filePath = idx >= 0 ? fp.slice(idx + CONTENT_ROOT.length) : `${doc.id}.md`;
---

<DocLayout
  title={doc.data.title}
  description={doc.data.description}
  category={doc.data.category}
  lastUpdated={doc.data.last_updated}
  filePath={filePath}
  headings={headings}
>
  <Content />
</DocLayout>
