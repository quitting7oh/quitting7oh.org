---
import { getCollection } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';
import { SidebarShell } from '~/components/SidebarShell';
import { Breadcrumbs } from '~/components/Breadcrumbs';
import { CATEGORIES, getCategory, PINNED_PAGES } from '~/lib/categories';
import { getSidebarCategories } from '~/lib/sidebar-data';

export async function getStaticPaths() {
  return CATEGORIES.map((cat) => ({ params: { category: cat.slug } }));
}

const { category } = Astro.params;
const cat = getCategory(category!);
if (!cat) return Astro.redirect('/');

const docs = await getCollection('docs', (d) => !d.data.draft && d.data.category === category);
docs.sort((a, b) => {
  const sa = a.data.sort ?? 999;
  const sb = b.data.sort ?? 999;
  if (sa !== sb) return sa - sb;
  return a.data.title.localeCompare(b.data.title);
});

const sidebarCategories = await getSidebarCategories();
const currentPath = Astro.url.pathname;
---

<BaseLayout title={cat.title} description={cat.blurb}>
  <SidebarShell
    client:load
    categories={sidebarCategories}
    pinned={PINNED_PAGES}
    currentPath={currentPath}
  >
    <main id="main-content" class="min-w-0 flex-1 py-8 lg:py-12">
      <div class="mx-auto max-w-[52rem]">
        <Breadcrumbs client:load crumbs={[{ label: cat.title }]} />
        <h1 class="font-display flex items-center gap-3 text-3xl font-semibold tracking-tight text-foreground sm:text-4xl">
          <cat.Icon class="h-7 w-7 shrink-0 text-muted-foreground sm:h-8 sm:w-8" aria-hidden="true" />
          <span>{cat.title}</span>
        </h1>
        <p class="mt-3 text-lg text-muted-foreground">{cat.blurb}</p>

        {docs.length === 0 ? (
          <p class="mt-10 text-muted-foreground">No pages here yet.</p>
        ) : (
          <ul class="mt-10 divide-y divide-border">
            {docs.map((doc) => {
              const slug = doc.id.replace(/\.(md|mdx)$/, '').split('/').pop()!;
              return (
                <li class="py-4">
                  <a href={`/${cat.slug}/${slug}`} class="group block">
                    <h2 class="text-lg font-semibold text-foreground group-hover:text-primary">
                      {doc.data.title}
                    </h2>
                    {doc.data.description && (
                      <p class="mt-1 text-sm text-muted-foreground">{doc.data.description}</p>
                    )}
                  </a>
                </li>
              );
            })}
          </ul>
        )}
      </div>
    </main>
  </SidebarShell>
</BaseLayout>
