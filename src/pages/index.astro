---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { NextMeeting } from '~/components/NextMeeting';
import { AppSidebar } from '~/components/AppSidebar';
import { DiscordOnlineCount } from '~/components/DiscordOnlineCount';
import { CATEGORIES, PINNED_PAGES } from '~/lib/categories';
import { getSidebarCategories } from '~/lib/sidebar-data';
import { getCollection } from 'astro:content';
import { LifeBuoy, HelpCircle, Signpost, Users, MessageCircle, BookOpen } from 'lucide-react';

const docs = await getCollection('docs', (d) => !d.data.draft);
const sidebarCategories = await getSidebarCategories();

const counts = Object.fromEntries(
  CATEGORIES.map((c) => [c.slug, docs.filter((d) => d.data.category === c.slug).length]),
);

const hotPaths = [
  {
    href: '/start-here/7-oh-withdrawal-help',
    Icon: LifeBuoy,
    title: 'In active withdrawal right now?',
    sub: 'What to do this hour',
    tone: 'crisis',
  },
  {
    href: '/start-here/how-to-quit-7-oh',
    Icon: Signpost,
    title: 'Ready to quit?',
    sub: 'The six paths, ranked by what fits',
    tone: 'neutral',
  },
  {
    href: '/for-loved-ones/welcome',
    Icon: Users,
    title: 'Loving someone going through this?',
    sub: 'For family, partners, friends',
    tone: 'neutral',
  },
  {
    href: '/start-here/what-is-7-oh',
    Icon: HelpCircle,
    title: 'What the hell is 7-OH?',
    sub: '60-second explainer',
    tone: 'neutral',
  },
];
---

<BaseLayout>
  {/* Mobile-only: mount AppSidebar to power the hamburger drawer.
      Sheet renders to body via Radix Portal, so being inside lg:hidden
      doesn't block it. Desktop suppresses the inline aside entirely so
      the homepage layout stays centered without a sidebar column. */}
  <div class="lg:hidden">
    <AppSidebar
      client:load
      categories={sidebarCategories}
      pinned={PINNED_PAGES}
      currentPath={Astro.url.pathname}
    />
  </div>

  <main id="main-content">
    {/* Hero: title + tight tagline + search */}
    <section class="mx-auto max-w-5xl px-4 pt-12 pb-6 sm:px-6 sm:pt-16 lg:px-8">
      <h1 class="font-display text-balance text-3xl font-semibold tracking-tight text-foreground sm:text-4xl">
        A calm reference for getting off 7-OH and kratom synthetics.
      </h1>
      <p class="mt-4 max-w-2xl text-lg leading-relaxed text-muted-foreground">
        Community-compiled by people who have been through it, for people going through it now and
        the ones who love them.
      </p>
    </section>

    {/* Next live meeting (KA + TIAWO) in the viewer's local timezone.
        Placed above the hot list so it's visible on mobile without
        scrolling past four stacked hot-list cards. client:load: the
        widget needs `new Date()` at render time and the viewer's IANA
        tz, neither known at build time. */}
    <section class="mx-auto max-w-5xl px-4 py-4 sm:px-6 lg:px-8">
      <NextMeeting client:load />
    </section>

    {/* Hot list: four funnel paths (crisis card gets amber emphasis) */}
    <section class="mx-auto max-w-5xl px-4 py-4 sm:px-6 lg:px-8">
      <h2 class="mb-3 text-xs font-semibold uppercase tracking-wider text-muted-foreground">
        Start here
      </h2>
      <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
        {hotPaths.map(({ href, Icon, title, sub, tone }) => (
          <a
            href={href}
            class:list={[
              'group flex items-start gap-3 rounded-lg border px-4 py-3 transition',
              tone === 'crisis'
                ? 'border-2 border-amber-500 bg-amber-50 hover:bg-amber-100 dark:border-amber-400 dark:bg-amber-950/40 dark:hover:bg-amber-950/70'
                : 'border-border bg-card hover:border-accent-400 hover:bg-accent-50/40 dark:hover:border-accent-500 dark:hover:bg-accent-950/30',
            ]}
          >
            <Icon
              class={tone === 'crisis'
                ? 'mt-0.5 h-5 w-5 shrink-0 text-amber-700 dark:text-amber-300'
                : 'mt-0.5 h-5 w-5 shrink-0 text-accent-700 dark:text-accent-300'}
              aria-hidden="true"
            />
            <span class="flex-1">
              <span class={tone === 'crisis'
                ? 'block font-semibold text-amber-900 dark:text-amber-100'
                : 'block font-semibold text-foreground'}>
                {title}
              </span>
              <span class={tone === 'crisis'
                ? 'block text-sm text-amber-800/80 dark:text-amber-200/80'
                : 'block text-sm text-muted-foreground'}>
                {sub} →
              </span>
            </span>
          </a>
        ))}
      </div>
    </section>

    {/* Community: Reddit (first per house preference) + Discord, as
        proper cards mirroring the hot-list pattern. About-link sits
        below as a small text link. */}
    <section class="mx-auto max-w-5xl px-4 py-4 sm:px-6 lg:px-8">
      <h2 class="mb-3 text-xs font-semibold uppercase tracking-wider text-muted-foreground">
        Live community
      </h2>
      <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
        <a
          href="https://www.reddit.com/r/quitting7oh/"
          target="_blank"
          rel="noopener noreferrer"
          class="group flex items-start gap-3 rounded-lg border border-border bg-card px-4 py-3 transition hover:border-accent-400 hover:bg-accent-50/40 dark:hover:border-accent-500 dark:hover:bg-accent-950/30"
        >
          <BookOpen class="mt-0.5 h-5 w-5 shrink-0 text-accent-700 dark:text-accent-300" aria-hidden="true" />
          <span class="flex-1">
            <span class="block font-semibold text-foreground">r/quitting7oh</span>
            <span class="block text-sm text-muted-foreground">Searchable archive, stories, longform threads →</span>
          </span>
        </a>
        <a
          href="https://discord.gg/quitting7oh"
          target="_blank"
          rel="noopener noreferrer"
          class="group flex items-start gap-3 rounded-lg border-2 border-emerald-500 bg-emerald-50 px-4 py-3 transition hover:bg-emerald-100 dark:border-emerald-400 dark:bg-emerald-950/40 dark:hover:bg-emerald-950/70"
        >
          <MessageCircle class="mt-0.5 h-5 w-5 shrink-0 text-emerald-700 dark:text-emerald-300" aria-hidden="true" />
          <span class="flex-1">
            <span class="block font-semibold text-emerald-900 dark:text-emerald-100">
              Discord<DiscordOnlineCount client:idle />
            </span>
            <span class="block text-sm text-emerald-800/80 dark:text-emerald-200/80">Real-time chat, live meetings, peers right now →</span>
          </span>
        </a>
      </div>
      <p class="mt-3 text-sm">
        <a
          href="/about/the-community"
          class="inline-flex items-center gap-1 text-muted-foreground hover:text-foreground"
        >
          About the community <span aria-hidden="true">→</span>
        </a>
      </p>
    </section>

    {/* Browse by topic: denser list, no chunky cards. Two columns on
        wider viewports; one column on mobile. Sidebar already exposes
        the full hierarchy, so this is a supplementary overview. */}
    <section class="mx-auto max-w-5xl px-4 py-6 sm:px-6 lg:px-8">
      <h2 class="mb-3 text-xs font-semibold uppercase tracking-wider text-muted-foreground">
        Browse by topic
      </h2>
      <div class="grid grid-cols-1 gap-x-6 gap-y-1 sm:grid-cols-2">
        {CATEGORIES.map((cat) => (
          <a
            href={`/${cat.slug}`}
            class="group flex items-start gap-3 rounded border border-transparent px-2 py-2 transition hover:border-border hover:bg-accent-50/30 dark:hover:bg-accent-950/20"
          >
            <cat.Icon class="mt-1 h-4 w-4 shrink-0 text-accent-700 dark:text-accent-300" aria-hidden="true" />
            <span class="flex-1">
              <span class="block text-sm font-semibold text-foreground group-hover:text-accent-700 dark:group-hover:text-accent-300">
                {cat.title}
                <span class="ml-1 text-xs font-normal text-muted-foreground">({counts[cat.slug]})</span>
              </span>
              <span class="block text-xs leading-snug text-muted-foreground">{cat.blurb}</span>
            </span>
          </a>
        ))}
      </div>
    </section>

    {/* Medical-territory framing. Sits at the bottom on purpose: the
        reader who is actually in withdrawal does not need a disclaimer
        between them and the crisis card. */}
    <section class="mx-auto max-w-5xl px-4 pb-16 pt-4 sm:px-6 lg:px-8">
      <div class="callout-medical">
        <p class="m-0 font-semibold text-zinc-800 dark:text-zinc-100">
          A note before you read anything else
        </p>
        <p class="mt-2 text-sm text-zinc-700 dark:text-zinc-300">
          Recovery is medical territory. The information here is meant to help you bring lived
          experience and better questions into the conversation with your prescriber, not replace
          that conversation. For most medical decisions a clinician who knows your situation will
          have context you don't — listen to them. For a few (like Suboxone starting doses and
          taper pacing) the community has hands-on experience worth bringing to the table. Both
          sides of that conversation matter.
        </p>
      </div>
    </section>
  </main>
</BaseLayout>
